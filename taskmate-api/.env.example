# --- Express (API HTTP): puerto 3000. NO es el puerto de MySQL (3306 → DB_PORT). ---
PORT=3000
# Orígenes del front (coma si hay varios): Ionic ~8100, ng serve ~4200
CORS_ORIGIN=http://localhost:8100,http://localhost:4200

# --- MySQL: igual que en Workbench (Host, Puerto, Usuario, contraseña al conectar) ---
# Puedes usar localhost o 127.0.0.1
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=taskmate

