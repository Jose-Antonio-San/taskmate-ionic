{
  "name": "taskmate-api",
  "version": "1.0.0",
  "private": true,
  "description": "REST API for TaskMate (Express + MySQL)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js"
  },
  "engines": {
    "node": ">=18"
  },
  "nodemonConfig": {
    "watch": ["server.js", "src"],
    "ext": "js,json",
    "ignore": ["node_modules/**"]
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "mysql2": "^3.11.4"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
